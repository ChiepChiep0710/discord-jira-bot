# Discord
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_channel_id_here

# Jira
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your_email@company.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_PROJECT_KEY=PROJ

# Lịch nhắc (cron format): mặc định 9h sáng mỗi ngày thứ 2-6
REMIND_CRON_HOUR=9
REMIND_CRON_MINUTE=0

# Map Jira username (name) -> Discord userId (JSON string)
# Jira Server dùng username (cột "name"), không phải accountId
# Lấy Discord userId: bật Developer Mode -> chuột phải user -> Copy User ID
# Ví dụ: {"linhdk@dxtech.vn": "111222333444555666", "datdt": "777888999000111222"}
JIRA_DISCORD_USER_MAP={}
